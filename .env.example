# Anthropic API 키 (https://console.anthropic.com 에서 발급)
# 이 파일을 복사해 .env 로 만들고 키를 넣으세요.
ANTHROPIC_API_KEY=sk-ant-여기에-키-입력

# (선택) 사용할 모델. 기본 claude-sonnet-4-6
#   가장 저렴: claude-haiku-4-5  /  품질 우선: claude-opus-4-8
# ANTHROPIC_MODEL=claude-sonnet-4-6

# (선택) 백엔드 포트. 기본 3001
# PORT=3001

# ── 비용 보호 (배포 시 과금 폭주 방지) ──
# 분석 1회마다 Claude Vision 호출 비용이 발생합니다. 아래로 요청 수를 제한하세요.

# 요청당 출력 토큰 상한 — 요청 1건의 비용 상한선. 기본 12000
# MAX_OUTPUT_TOKENS=12000

# IP별 시간당 분석 횟수. 기본 5
# RATE_LIMIT_HOURLY=5

# IP별 하루 분석 횟수. 기본 20
# RATE_LIMIT_DAILY=20

# 전체(모든 사용자 합산) 하루 분석 횟수 상한 — 하루 총비용의 안전장치. 기본 200
# GLOBAL_DAILY_CAP=200

# 프로덕션 배포 시: NODE_ENV=production 으로 두면 빌드된 dist 를 함께 서빙합니다.
# NODE_ENV=production
