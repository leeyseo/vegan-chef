# Google Gemini API 키 (무료) — https://aistudio.google.com 에서 발급
# 이 파일을 복사해 .env 로 만들고 키를 넣으세요.
GEMINI_API_KEY=여기에-키-입력

# (선택) 사용할 모델. 기본 gemini-2.5-flash (무료 티어, 품질↑)
#   더 높은 품질: gemini-2.5-pro (무료 한도 더 빡셈) / 더 빠름: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# (선택) 백엔드 포트. 기본 3001
# PORT=3001

# ── 남용/한도 보호 (무료 티어 분당·일일 한도 보호) ──
# 요청당 출력 토큰 상한. 기본 8000
# MAX_OUTPUT_TOKENS=8000
# IP별 시간당 분석 횟수. 기본 5
# RATE_LIMIT_HOURLY=5
# IP별 하루 분석 횟수. 기본 20
# RATE_LIMIT_DAILY=20
# 전체(모든 사용자 합산) 하루 분석 횟수 상한. 기본 200
# GLOBAL_DAILY_CAP=200

# 프로덕션 배포 시: NODE_ENV=production 으로 두면 빌드된 dist 를 함께 서빙합니다.
# NODE_ENV=production
